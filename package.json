{
  "name": "corporate-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@9.0.0",
  "scripts": {
    "dev": "cross-env PORT=3000 next dev --turbopack",
    "dev:webpack": "cross-env PORT=3000 next dev --webpack",
    "build": "next build --webpack",
    "build:analyze": "npx next build --webpack --experimental-profile",
    "analyze": "cross-env ANALYZE=true next build --webpack",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "dep:unused": "npx knip",
    "check:ts": "node node_modules/typescript/bin/tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "plugins:check": "npx knip"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.38.0",
    "isomorphic-dompurify": "^3.17.0",
    "lru-cache": "^7.11.0",
    "lucide-react": "^1.7.0",
    "next": "^16.2.9",
    "nodemailer": "^8.0.5",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sonner": "^2.0.7",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.9",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "knip": "^6.17.1",
    "postcss": "^8.5.15",
    "server-only": "^0.0.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
